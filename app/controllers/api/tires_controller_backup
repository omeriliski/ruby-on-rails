        def update
            # @tire = get_tire
            if @tire.update(tire_params)
                @message = "Tire updated successfully"
                render :update, status: :ok
            else
                @message = "Tire update failed"
                handler_error
            end
            # render json: tire_data(@tire)
        end

        def destroy
            # @tire = get_tire
            if(@tire.destroy)
                @message = "Tire deleted successfully"
                render :destroy, status: :ok
            else
                @message = "Tire deletion failed"
                handler_error
            end
            # render json: { message: "Tire deleted successfully" }
        end

        private
        def handle_error
            render :error,status: :bad_request
        end

        def tire_params
            params.permit(:name, :brand_id, :width, :height, :inch, :season, :price, :list_price, :stock, :sku, :description, :tire_image)
        end

        def get_tire
            @tire = Tire.find(params[:id])
        end

        def tire_data(tire)
            tire.as_json(except: [:brand_id], include: :brand)
        end

        def log_after_create
            p "tire size is successfully created with id: #{self.id}"
        end

