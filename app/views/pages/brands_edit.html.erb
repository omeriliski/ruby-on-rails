<h1>Edit Brand</h1>

<form id="brandForm" style="max-width: 600px;" data-brand-id="<%= @brand.id %>">
  <div style="margin-bottom: 1rem;">
    <label for="brand_name" style="display: block; margin-bottom: 0.5rem;"><strong>Brand Name *</strong></label>
    <input type="text" id="brand_name" name="name" value="<%= @brand.name %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
  </div>

  <button type="submit" style="background: #28a745; color: white; padding: 0.75rem 1.5rem; border: none; border-radius: 4px; cursor: pointer; margin-right: 0.5rem;">Update Brand</button>
  <%= link_to 'Cancel', brands_path, style: 'display: inline-block; background: #6c757d; color: white; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 4px;' %>
</form>

<script>
  document.getElementById('brandForm').addEventListener('submit', async (e) => {
    e.preventDefault()
    
    const brandId = document.getElementById('brandForm').dataset.brandId
    const formData = new FormData(e.target)
    const data = Object.fromEntries(formData)
    const token = localStorage.getItem('auth_token')
    
    try {
      const response = await fetch(`/api/brands/${brandId}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Authorization': token ? `Bearer ${token}` : ''
        },
        body: JSON.stringify(data)
      })

      const result = await response.json()

      if (response.ok) {
        alert('Brand updated successfully!')
        window.location.href = '/brands'
      } else {
        alert('Error: ' + (result.message || JSON.stringify(result)))
      }
    } catch (error) {
      console.error('Error:', error)
      alert('Request failed: ' + error.message)
    }
  })
</script>
