<h1>All Brands</h1>

<table style="width: 100%; border-collapse: collapse; margin-bottom: 2rem;">
  <thead>
    <tr style="background: #f5f5f5;">
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">ID</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Name</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Created At</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @brands.each do |brand| %>
      <tr style="border: 1px solid #ddd;">
        <td style="padding: 0.5rem; border: 1px solid #ddd;"><%= brand.id %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;"><%= brand.name %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;"><%= brand.created_at.strftime('%Y-%m-%d') %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;">
          <% if user_signed_in? %>
            <%= link_to 'Edit', brands_edit_path(brand), style: 'color: #ffc107; text-decoration: none; margin-right: 0.5rem;' %>
            <a href="#" onclick="deleteBrand(<%= brand.id %>); return false;" style="color: #dc3545; text-decoration: none; cursor: pointer;">Delete</a>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if user_signed_in? %>
  <%= link_to 'Add New Brand', brands_new_path, style: 'display: inline-block; background: #28a745; color: white; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px;' %>
<% end %>

<script>
  function deleteBrand(brandId) {
    if (!confirm('Are you sure you want to delete this brand?')) return
    
    const token = localStorage.getItem('auth_token')
    
    fetch(`/api/brands/${brandId}`, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Authorization': token ? `Bearer ${token}` : ''
      }
    })
    .then(() => {
      alert('Brand deleted successfully!')
      window.location.reload()
    })
    .catch(error => {
      console.error('Error:', error)
      alert('Failed to delete brand')
    })
  }
</script>
