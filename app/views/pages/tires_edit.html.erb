<h1>Edit Tire</h1>

<form id="tireForm" style="max-width: 600px;" data-tire-id="<%= @tire.id %>">
  <div style="margin-bottom: 1rem;">
    <label for="tire_name" style="display: block; margin-bottom: 0.5rem;"><strong>Name *</strong></label>
    <input type="text" id="tire_name" name="name" value="<%= @tire.name %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
  </div>

  <div style="margin-bottom: 1rem;">
    <label for="tire_brand_id" style="display: block; margin-bottom: 0.5rem;"><strong>Brand *</strong></label>
    <select id="tire_brand_id" name="brand_id" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
      <% @brands.each do |brand| %>
        <option value="<%= brand.id %>" <%= 'selected' if @tire.brand_id == brand.id %> ><%= brand.name %></option>
      <% end %>
    </select>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
    <div>
      <label for="tire_width" style="display: block; margin-bottom: 0.5rem;"><strong>Width *</strong></label>
      <input type="number" id="tire_width" name="width" value="<%= @tire.width %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
    </div>
    <div>
      <label for="tire_height" style="display: block; margin-bottom: 0.5rem;"><strong>Height *</strong></label>
      <input type="number" id="tire_height" name="height" value="<%= @tire.height %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
    <div>
      <label for="tire_inch" style="display: block; margin-bottom: 0.5rem;"><strong>Inch *</strong></label>
      <input type="text" id="tire_inch" name="inch" value="<%= @tire.inch %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
    </div>
    <div>
      <label for="tire_season" style="display: block; margin-bottom: 0.5rem;"><strong>Season *</strong></label>
      <select id="tire_season" name="season" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
        <option value="summer" <%= 'selected' if @tire.season == 'summer' %>>Summer</option>
        <option value="winter" <%= 'selected' if @tire.season == 'winter' %>>Winter</option>
        <option value="all-season" <%= 'selected' if @tire.season == 'all-season' %>>All-Season</option>
      </select>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
    <div>
      <label for="tire_price" style="display: block; margin-bottom: 0.5rem;"><strong>Price *</strong></label>
      <input type="number" id="tire_price" name="price" value="<%= @tire.price %>" step="0.01" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
    </div>
    <div>
      <label for="tire_list_price" style="display: block; margin-bottom: 0.5rem;"><strong>List Price</strong></label>
      <input type="number" id="tire_list_price" name="list_price" value="<%= @tire.list_price %>" step="0.01" style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
    </div>
  </div>

  <div style="margin-bottom: 1rem;">
    <label for="tire_stock" style="display: block; margin-bottom: 0.5rem;"><strong>Stock *</strong></label>
    <input type="number" id="tire_stock" name="stock" value="<%= @tire.stock %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
  </div>

  <div style="margin-bottom: 1rem;">
    <label for="tire_sku" style="display: block; margin-bottom: 0.5rem;"><strong>SKU *</strong></label>
    <input type="text" id="tire_sku" name="sku" value="<%= @tire.sku %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
  </div>

  <div style="margin-bottom: 1rem;">
    <label for="tire_description" style="display: block; margin-bottom: 0.5rem;"><strong>Description *</strong></label>
    <textarea id="tire_description" name="description" required style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px; min-height: 100px;"><%= @tire.description %></textarea>
  </div>

  <button type="submit" style="background: #28a745; color: white; padding: 0.75rem 1.5rem; border: none; border-radius: 4px; cursor: pointer; margin-right: 0.5rem;">Update Tire</button>
  <%= link_to 'Cancel', tires_path(@tire), style: 'display: inline-block; background: #6c757d; color: white; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 4px;' %>
</form>

<script>
  document.getElementById('tireForm').addEventListener('submit', async (e) => {
    e.preventDefault()
    
    const tireId = document.getElementById('tireForm').dataset.tireId
    const formData = new FormData(e.target)
    const data = Object.fromEntries(formData)
    const token = localStorage.getItem('auth_token')
    
    try {
      const response = await fetch(`/api/tires/${tireId}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Authorization': token ? `Bearer ${token}` : ''
        },
        body: JSON.stringify(data)
      })

      const result = await response.json()

      if (response.ok) {
        alert('Tire updated successfully!')
        window.location.href = `/tires/${tireId}`
      } else {
        alert('Error: ' + (result.message || JSON.stringify(result)))
      }
    } catch (error) {
      console.error('Error:', error)
      alert('Request failed: ' + error.message)
    }
  })
</script>
