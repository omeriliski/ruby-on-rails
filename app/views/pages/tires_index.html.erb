<h1>All Tires</h1>

<table style="width: 100%; border-collapse: collapse; margin-bottom: 2rem;">
  <thead>
    <tr style="background: #f5f5f5;">
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">ID</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Name</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Price</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Season</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Stock</th>
      <th style="text-align: left; padding: 0.5rem; border: 1px solid #ddd;">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @tires.each do |tire| %>
      <tr style="border: 1px solid #ddd;">
        <td style="padding: 0.5rem; border: 1px solid #ddd;"><%= tire.id %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;"><%= link_to tire.name, tires_show_path(tire), style: 'color: #007bff; text-decoration: none;' %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;">$<%= tire.price %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;"><%= tire.season %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;"><%= tire.stock %></td>
        <td style="padding: 0.5rem; border: 1px solid #ddd;">
          <%= link_to 'Show', tires_show_path(tire), style: 'color: #007bff; text-decoration: none; margin-right: 0.5rem;' %>
          <% if user_signed_in? %>
            <%= link_to 'Edit', tires_edit_path(tire), style: 'color: #ffc107; text-decoration: none; margin-right: 0.5rem;' %>
            <a href="#" onclick="deleteTire(<%= tire.id %>); return false;" style="color: #dc3545; text-decoration: none; cursor: pointer;">Delete</a>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if user_signed_in? %>
  <%= link_to 'Add New Tire', tires_new_path, style: 'display: inline-block; background: #007bff; color: white; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px;' %>
<% end %>

<script>
  function deleteTire(tireId) {
    if (!confirm('Are you sure you want to delete this tire?')) return
    
    const token = localStorage.getItem('auth_token')
    
    fetch(`/api/tires/${tireId}`, {
      method: 'DELETE',
      headers: {
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Authorization': token ? `Bearer ${token}` : ''
      }
    })
    .then(() => {
      alert('Tire deleted successfully!')
      window.location.reload()
    })
    .catch(error => {
      console.error('Error:', error)
      alert('Failed to delete tire')
    })
  }
</script>
